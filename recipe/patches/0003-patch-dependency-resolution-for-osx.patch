From 244d733f55a87d92b17ec6a6b78549e2ae5bf172 Mon Sep 17 00:00:00 2001
From: Giordon Stark <kratsg@gmail.com>
Date: Wed, 25 Feb 2026 06:25:10 +0100
Subject: [PATCH] [PATCH] patching for dependency resolution for osx

---
 src/libSpec/CMakeLists.txt |  4 ++++
 src/libYarr/CMakeLists.txt | 12 ++++++++++--
 2 files changed, 14 insertions(+), 2 deletions(-)

diff --git a/src/libSpec/CMakeLists.txt b/src/libSpec/CMakeLists.txt
index 711f2e33..cfb13eac 100644
--- a/src/libSpec/CMakeLists.txt
+++ b/src/libSpec/CMakeLists.txt
@@ -22,6 +22,10 @@ target_include_directories(Spec PUBLIC
 
 target_link_libraries(Spec PRIVATE Util_interface Yarr_interface)
 
+if(APPLE)
+    target_link_options(Spec PRIVATE "-Wl,-undefined,dynamic_lookup")
+endif()
+
 LIST(APPEND apps
 	specReadWriteReg
         config-GBT-FMC
diff --git a/src/libYarr/CMakeLists.txt b/src/libYarr/CMakeLists.txt
index c9c6da74..40d73f52 100644
--- a/src/libYarr/CMakeLists.txt
+++ b/src/libYarr/CMakeLists.txt
@@ -5,13 +5,18 @@ add_library(Yarr SHARED
 target_include_directories(Yarr PUBLIC
     $<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}/include>
     # for the yarr_version.h which is created in the binary tree
-    $<BUILD_INTERFACE:${PROJECT_BINARY_DIR}/src/libYarr/include> 
+    $<BUILD_INTERFACE:${PROJECT_BINARY_DIR}/src/libYarr/include>
     $<INSTALL_INTERFACE:${CMAKE_INSTALL_INCLUDEDIR}>
 )
 target_link_libraries(Yarr ${CONTROLLERS})
 target_link_libraries(Yarr ${FRONT_ENDS})
 target_link_libraries(Yarr Util_interface)
-target_link_options(Yarr PUBLIC -Wl,--no-as-needed)
+if(APPLE)
+  set(YARR_LINK_OPTION "-Wl,-undefined,dynamic_lookup")
+else()
+  set(YARR_LINK_OPTION "-Wl,--no-as-needed")
+endif()
+target_link_options(Yarr PUBLIC ${YARR_LINK_OPTION})
 
 post_build_debug_library(Yarr)
 
@@ -95,6 +100,9 @@ target_include_directories(Scan PUBLIC
     $<INSTALL_INTERFACE:${CMAKE_INSTALL_INCLUDEDIR}>
 )
 target_link_libraries(Scan Util)
+if(APPLE)
+    target_link_options(Scan PRIVATE "-Wl,-undefined,dynamic_lookup")
+endif()
 
 target_compile_options(
     Scan
-- 
2.45.2

